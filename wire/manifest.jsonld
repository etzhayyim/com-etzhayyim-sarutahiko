  ],
  "operatorSideCounterpart": "wadachi (轍, ADR-2605242000) — same vehicle, operator vs manufacturer split. Vehicles produced by sarutahiko are operated under wadachi gates.",
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Heavy truck manufacturing (Wave 1 = civilian Class-8 cargo truck, ~26-40 t GVWR)",
    "wave1Reference": "Civilian Class-8 cargo truck (~26-40 t GVWR, 6×2 / 6×4 drive) end-to-end frame → powertrain → cab → marriage → paint → electrical → QA → VIN attestation",
    "wavesDeferred": [
      "Wave 2: Mid + light commercial (Class 3-7, ~3.5–7.5 t GVWR) — separate ADR",
      "Wave 3: Civilian specialty (fire engine + ambulance + cold-chain refrigerated logistics; §1.13 wellbecoming positive) — separate ADR"
    ],
    "exclusions": [
      "Military trucks (4×4/6×6 troop, MRAP, armored) (N1)",
      "Weapons + ammunition transport (N2)",
      "Riot control / water-cannon / armored police (N3)",
      "Mining haul trucks (N4)",
      "Fossil fuel tankers (N5; bio-fuel + water + food tankers in scope)",
      "Military surveillance vehicles (N6)",
      "Fully autonomous unmanned military platforms (N7)",
      "Proprietary ECU NDA (N8)",
      "Driver-suppression UX (N9)",
      "Pure-fossil-only powertrain at R2+ (N10)",
      "Mobile billboard / LED advertising trucks (N11)",
      "For-profit MaaS rental fleets (N12; non-profit member delivery + community logistics in scope)"
    ]
  },
  "roboticsClasses": [
    "Kasane (重ね) — heavy-frame welding manipulator (HSLA-590/780 multi-pass) (new, R1+)",
    "Tsutsumi (包み) — paint booth robot (water-based KTL, VOC <100 g/L) (new, R2+)",
    "Akari (灯り) — electrical harness + ECU flash + diagnostics binder (new, R1+)",
    "Norimichi (乗道) — public-road test driver, SAE Level 3 driver-in-seat (new, R2+; wadachi inheritance)",
    "Otete-heavy — kuni-umi Otete heavy-payload ≥200 kg variant (R1+)",
    "Mimi-precision — kuni-umi Mimi μm-level alignment (R1+)",
    "Migaki — kanayama coil + body-panel surface inspector reuse (R2+)"
  ],
  "cells": [
    {"name": "frame_fabrication", "module": "sarutahiko.cells.frame-fabrication.state-machine", "murakumoNode": "naphtali", "phase": "L1 — chassis frame robotic MIG/MAG welding"},
    {"name": "powertrain_assembly", "module": "sarutahiko.cells.powertrain-assembly.state-machine", "murakumoNode": "joseph", "phase": "L2 — engine + transmission + axle (G7 fuel guard)"},
    {"name": "cab_body_forming", "module": "sarutahiko.cells.cab-body-forming.state-machine", "murakumoNode": "zebulun", "phase": "L3 — cab hot stamping + spot welding + leak test"},
    {"name": "final_marriage", "module": "sarutahiko.cells.final-marriage.state-machine", "murakumoNode": "simeon", "phase": "L4 — chassis + cab + powertrain marriage (≥2 robot witness)"},
    {"name": "paint_finishing", "module": "sarutahiko.cells.paint-finishing.state-machine", "murakumoNode": "simeon", "phase": "L5a — KTL primer + base + clear (water-based, VOC <100 g/L)"},
    {"name": "electrical_integration", "module": "sarutahiko.cells.electrical-integration.state-machine", "murakumoNode": "levi", "phase": "L5b — harness + ECU flash (G1 open-source) + diagnostics"},
    {"name": "quality_road_test", "module": "sarutahiko.cells.quality-road-test.state-machine", "murakumoNode": "levi", "phase": "L5c — roller dyno + 50 km public-road test"},
    {"name": "emissions_audit", "module": "sarutahiko.cells.emissions-audit.state-machine", "murakumoNode": "levi", "phase": "cross-cutting — Euro 7 + 大気汚染防止法 + Bharat VI compliance"},
    {"name": "vin_attestation_binder", "module": "sarutahiko.cells.vin-attestation-binder.state-machine", "murakumoNode": "judah", "phase": "terminal — per-VIN kotoba-datomic anchor (G2 + G13)"}
